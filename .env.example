# .env.example — PashuMitra Phase 2

# ── WhatsApp (Meta Cloud API) ─────────────────────────────────
WHATSAPP_VERIFY_TOKEN=your_verify_token_here
WHATSAPP_ACCESS_TOKEN=your_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# ── Database ──────────────────────────────────────────────────
# Development (SQLite — no setup needed)
DATABASE_URL=sqlite:///./pashumitra_dev.db
# Production (PostgreSQL)
# DATABASE_URL=postgresql://user:pass@localhost:5432/pashumitra

# ── AI APIs (Phase 2) ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-openai-key

# ── SMS Fallback (Twilio — optional) ─────────────────────────
SMS_PROVIDER=none    # Set to 'twilio' to enable
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+1234567890

# ── Cache (Redis — optional) ──────────────────────────────────
# Leave empty to use in-memory cache
REDIS_URL=redis://localhost:6379/0

# ── Runtime ──────────────────────────────────────────────────
ENVIRONMENT=development   # development | production
LOG_LEVEL=INFO
FREE_QUERIES_PER_DAY=3
